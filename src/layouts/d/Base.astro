---
import Seo from '../../components/Seo.astro';
import { withBase } from '../../lib/url';
import '../../styles/d.css';

interface Props {
  title: string;
  description: string;
  /** true on the home page — nav links become in-page anchors */
  home?: boolean;
}

const { title, description, home = false } = Astro.props;
const homeHref = withBase('d/');
const anchor = (id: string) => (home ? `#${id}` : `${homeHref}#${id}`);
---
<!doctype html>
<html lang="en">
  <head>
    <Seo title={title} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Archivo:ital,wght@0,400;0,500;0,600;0,700;0,800;1,500&family=Instrument+Serif:ital@0;1&display=swap"
    />
    <script is:inline>document.documentElement.classList.add('js');</script>
  </head>
  <body>
    <header class="topbar">
      <div class="wrap topbar-inner">
        <a class="topbar-logo" href={homeHref}>
          Niranjan<span class="star" aria-hidden="true">&nbsp;★&nbsp;</span>Rakesh
        </a>
        <nav class="topbar-links" aria-label="Site">
          <a href={anchor('work')}>Work</a>
          <a href={anchor('builds')} class="hide-sm">Builds</a>
          <a href={anchor('about')} class="hide-sm">About</a>
          <a href={anchor('archive')} class="hide-sm">Archive</a>
          <a href={anchor('contact')}>Contact</a>
        </nav>
      </div>
    </header>

    <slot />

    <nav class="dswitch" aria-label="Design direction switcher">
      <a href={withBase('')} title="Direction chooser">⌂</a>
      <a href={withBase('a/')} title="Direction A">A</a>
      <a href={withBase('b/')} title="Direction B">B</a>
      <a href={withBase('c/')} title="Direction C">C</a>
      <a href={withBase('d/')} class="active" aria-current="page" title="Direction D — Chroma">D</a>
    </nav>

    <script>
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const els = document.querySelectorAll('[data-reveal]');
      if (reduced || !('IntersectionObserver' in window)) {
        els.forEach((el) => el.classList.add('is-in'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-in');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.1, rootMargin: '0px 0px -6% 0px' }
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
