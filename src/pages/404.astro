---
import Seo from '../components/Seo.astro';
import { withBase } from '../lib/url';

const directions = [
  { key: 'a', name: 'Voltage', hue: '#7c3aed', hue2: '#22d3ee' },
  { key: 'b', name: 'Ink & Ochre', hue: '#c2410c', hue2: '#eab308' },
  { key: 'c', name: 'Machine', hue: '#16a34a', hue2: '#a3e635' },
];
---
<html lang="en">
  <head>
    <Seo
      title="404 — page not found · Niranjan Rakesh"
      description="That page doesn't exist. Head back to the direction chooser or jump straight into one of the three designs."
    />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      :global(body) {
        min-height: 100vh;
        background: #0a0a0a;
        color: #f5f5f4;
        font-family: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif;
      }
      main {
        min-height: 100vh;
        max-width: 1280px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: clamp(1.5rem, 5vw, 4rem);
      }
      .code {
        font-family: ui-monospace, 'SF Mono', Menlo, monospace;
        font-size: 0.8rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: #a8a29e;
        margin-bottom: 0.75rem;
      }
      h1 {
        font-size: clamp(1.8rem, 4.5vw, 3.2rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        margin-bottom: 1rem;
        max-width: 24ch;
        line-height: 1.05;
      }
      .sub {
        color: #a8a29e;
        line-height: 1.6;
        max-width: 46ch;
        margin-bottom: 2.5rem;
      }
      .home {
        display: inline-block;
        width: fit-content;
        color: #0a0a0a;
        background: #f5f5f4;
        text-decoration: none;
        font-weight: 650;
        font-size: 0.95rem;
        padding: 0.75rem 1.4rem;
        border-radius: 999px;
        margin-bottom: 2.5rem;
        transition: transform 0.25s ease, background 0.25s ease;
      }
      .home:hover { transform: translateY(-2px); background: #fff; }
      a:focus-visible { outline: 2px solid #22d3ee; outline-offset: 3px; }
      .or {
        font-family: ui-monospace, 'SF Mono', Menlo, monospace;
        font-size: 0.72rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #57534e;
        margin-bottom: 0.9rem;
      }
      .row { display: flex; flex-wrap: wrap; gap: 0.75rem; }
      a.dir {
        display: flex;
        align-items: baseline;
        gap: 0.6rem;
        padding: 0.8rem 1.2rem;
        border: 1px solid #292524;
        border-radius: 14px;
        text-decoration: none;
        color: inherit;
        background: linear-gradient(180deg, #141414, #0d0d0d);
        transition: transform 0.25s ease, border-color 0.25s ease;
      }
      a.dir:hover { transform: translateY(-3px); border-color: #44403c; }
      .key {
        font-family: ui-monospace, 'SF Mono', Menlo, monospace;
        font-size: 0.72rem;
        letter-spacing: 0.15em;
        color: var(--hue2);
      }
      .name { font-weight: 700; font-size: 0.98rem; }
    </style>
  </head>
  <body>
    <main>
      <p class="code">HTTP 404 — signal lost</p>
      <h1>This page doesn't exist. The work does.</h1>
      <p class="sub">
        The address may have moved while the three design directions are being
        compared. Start from the chooser, or jump straight into a direction.
      </p>
      <a class="home" href={withBase('')}>Back to the chooser →</a>
      <p class="or">Or open a direction</p>
      <div class="row">
        {directions.map((d) => (
          <a class="dir" href={withBase(`${d.key}/`)} style={`--hue2:${d.hue2}`}>
            <span class="key">/{d.key.toUpperCase()}</span>
            <span class="name">{d.name}</span>
          </a>
        ))}
      </div>
    </main>
  </body>
</html>
